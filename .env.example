# Supabase (PRD 9.7). Get these from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Xendit billing (PRD 7.6, 9.7). Use sandbox keys in development.
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Root domain the app is served on. Used by middleware to tell the app itself
# apart from a published site's subdomain (PRD 9.3, 9.7).
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
